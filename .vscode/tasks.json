{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-debug",
      "type": "shell",
      "command": "${workspaceFolder}\\.vscode\\build-debug-msvc.cmd",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$msCompile"
      ]
    },
    {
      "label": "build-release",
      "type": "shell",
      "command": "${workspaceFolder}\\.vscode\\build-release-msvc.cmd",
      "problemMatcher": [
        "$msCompile"
      ]
    },
    {
      "label": "build-relwithdebinfo",
      "type": "shell",
      "command": "${workspaceFolder}\\.vscode\\build-relwithdebinfo-msvc.cmd",
      "problemMatcher": [
        "$msCompile"
      ]
    },
    {
      "label": "build-asan",
      "type": "shell",
      "command": "${workspaceFolder}\\.vscode\\build-asan-msvc.cmd",
      "detail": "Experimental only. Full-app ASan is currently blocked by prebuilt third-party library ABI/runtime mismatches.",
      "problemMatcher": [
        "$msCompile"
      ]
    },
    {
      "label": "publish-release",
      "type": "shell",
      "command": "${workspaceFolder}\\.vscode\\publish-release-msvc.cmd",
      "detail": "Builds Release and publishes a runnable package to ${workspaceFolder}\\release",
      "problemMatcher": [
        "$msCompile"
      ]
    },
    {
      "label": "publish-release-slim",
      "type": "shell",
      "command": "${workspaceFolder}\\.vscode\\publish-release-slim-msvc.cmd",
      "detail": "Builds Release and publishes a slimmer runnable package to ${workspaceFolder}\\release-slim",
      "problemMatcher": [
        "$msCompile"
      ]
    }
  ]
}
